{
  "compilerOptions": {
    "strictNullChecks": false,
    "baseUrl": ".",
    "esModuleInterop": true,
    "jsx": "react-native",
    "lib": [
      "ESNext"
    ],
    "module": "CommonJS",
    "noEmit": true,
    "paths": {
      "react-native-media-builder": [
        "../src"
      ]
    },
    "skipLibCheck": true,
    "strict": true,
    "target": "ESNext",
    "noUnusedLocals": false,
    "noUnusedParameters": false,
  },
  "include": [
    "src"
  ]
}